MODEL_PROFILES_JSON=[{"id":"fixed:test","provider":"fixed","base_url":"","model":"deterministic-test","api_key_env":"","timeout_seconds":10},{"id":"openai:default","provider":"openai-compatible","base_url":"https://api.openai.com/v1","model":"gpt-4.1-mini","api_key_env":"OPENAI_API_KEY","timeout_seconds":60},{"id":"azure:gpt-4o-mini","provider":"azure-openai","base_url":"https://YOUR_RESOURCE.openai.azure.com","model":"YOUR_DEPLOYMENT_NAME","api_key_env":"AZURE_OPENAI_API_KEY","api_version":"2024-06-01","timeout_seconds":60},{"id":"ollama:local","provider":"ollama","base_url":"http://host.docker.internal:11434","model":"qwen3:8b","api_key_env":"","timeout_seconds":120}]
OPENAI_API_KEY=replace-with-your-key
AZURE_OPENAI_API_KEY=replace-with-your-azure-key
